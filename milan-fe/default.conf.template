server {
    listen 5000;
    server_name _;
    root /usr/share/nginx/html;
    index index.html;

    gzip on;
    gzip_types text/plain text/css application/json application/javascript text/xml application/xml image/svg+xml;

    # ─── Backend API: proxy /milan-aegis/api/* to the backend container ────────
    # The upstream hostname is templated at container start. The nginx
    # base image runs /docker-entrypoint.d/20-envsubst-on-templates.sh
    # against /etc/nginx/templates/*.template, so ${MILAN_BE_UPSTREAM}
    # is replaced by whatever the Deployment / docker-compose / OS env
    # provides. Examples:
    #   milan-be:5000                                  (same K8s namespace)
    #   milan-be.milan-be.svc.cluster.local:5000       (cross namespace, Aegis)
    #   host.docker.internal:5000                      (docker-compose alt)
    location ^~ /milan-aegis/api/ {
        resolver kube-dns.kube-system.svc.cluster.local 8.8.8.8 valid=10s ipv6=off;
        set $milan_be_upstream "${MILAN_BE_UPSTREAM}";
        proxy_pass http://$milan_be_upstream;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 60s;
    }

    # ─── SPA: serve the static bundle under /milan-aegis-fe/* ──────────────────
    location ^~ /milan-aegis-fe/ {
        rewrite ^/milan-aegis-fe/?(.*)$ /$1 break;
        try_files $uri $uri/index.html @spa_fallback;
    }

    # ─── Legacy redirect: /milan-fe/* → /milan-aegis-fe/* ──────────────────────
    location ^~ /milan-fe/ {
        rewrite ^/milan-fe/(.*)$ /milan-aegis-fe/$1 permanent;
    }
    location = /milan-fe {
        return 301 /milan-aegis-fe/;
    }

    # Internal-only fallback — serves /index.html for client-side routes inside
    # the SPA. Cannot be reached by external URLs (named locations are private).
    location @spa_fallback {
        try_files /index.html =404;
    }

    # ─── Root → SPA ────────────────────────────────────────────────────────────
    location = / {
        return 301 /milan-aegis-fe/;
    }

    # Everything else → 404.
    location / {
        return 404;
    }
}
